# ============================================================
# Nexus CRM — Variáveis de Ambiente
# Copiar para .env.production e preencher os valores reais
# ============================================================

# === Core (obrigatório) ===
DATABASE_URL=postgresql://nexus:password@db:5432/nexus_crm_krayin
REDIS_URL=redis://redis:6379
NEXTAUTH_SECRET=                    # gerar: openssl rand -base64 32
NEXTAUTH_URL=https://crm.nexusai360.com

# === Email [core] ===
RESEND_API_KEY=re_xxxxx

# === Admin Seed [core] ===
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=                     # senha inicial do super admin

# === Encryption [módulo: encryption] ===
ENCRYPTION_KEY=                     # 64 caracteres hex: openssl rand -hex 32

# === Email OAuth [Fase 7b] ===
# Deixar em branco mantém endpoints /api/oauth/* respondendo 503 (dry-run).
# Configurar para habilitar conexão Gmail/Outlook em produção.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://crm.nexusai360.com/api/oauth/gmail/callback
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
MS_OAUTH_REDIRECT_URI=https://crm.nexusai360.com/api/oauth/outlook/callback

# === Observability opcional [Fase 1c] ===
# Deixar em branco mantém Sentry/OTel em no-op mode.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
OTEL_EXPORTER_OTLP_ENDPOINT=

# === Logger [Fase 1c] ===
LOG_LEVEL=info

# === File Storage [Fase 6] ===
FILE_STORAGE_DRIVER=local
FILE_STORAGE_ROOT=/var/lib/nexus-crm/files

# === Backup [Fase 1c.2] ===
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=crm/daily
BACKUP_AGE_RECIPIENT=
BACKUP_AGE_IDENTITY=

# === Deploy ===
DB_PASSWORD=                        # senha do PostgreSQL
GHCR_TOKEN=                         # GitHub Container Registry token
PORTAINER_URL=https://portainer.exemplo.com
PORTAINER_TOKEN=                    # Portainer API token
PORTAINER_ENDPOINT_ID=1
