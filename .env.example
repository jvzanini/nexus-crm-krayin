# ============================================================
# Nexus CRM — Variáveis de Ambiente
# Copiar para .env.production e preencher os valores reais
# ============================================================

# === Core (obrigatório) ===
DATABASE_URL=postgresql://nexus:password@db:5432/nexus_crm_krayin
REDIS_URL=redis://redis:6379
NEXTAUTH_SECRET=                    # gerar: openssl rand -base64 32
NEXTAUTH_URL=https://crm.nexusai360.com

# === Email [core] ===
RESEND_API_KEY=re_xxxxx

# === Admin Seed [core] ===
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=                     # senha inicial do super admin

# === Encryption [módulo: encryption] ===
ENCRYPTION_KEY=                     # 64 caracteres hex: openssl rand -hex 32

# === Email OAuth [Fase 7b] ===
# Deixar em branco mantém endpoints /api/oauth/* respondendo 503 (dry-run).
# Configurar para habilitar conexão Gmail/Outlook em produção.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://crm.nexusai360.com/api/oauth/gmail/callback
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
MS_OAUTH_REDIRECT_URI=https://crm.nexusai360.com/api/oauth/outlook/callback

# === Observability opcional [Fase 1c] ===
# Deixar em branco mantém Sentry/OTel em no-op mode.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
OTEL_EXPORTER_OTLP_ENDPOINT=

# === Logger [Fase 1c] ===
LOG_LEVEL=info

# === File Storage [Fase 6] ===
FILE_STORAGE_DRIVER=local
FILE_STORAGE_ROOT=/var/lib/nexus-crm/files

# === Backup [Fase 1c.2] ===
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=crm/daily
BACKUP_AGE_RECIPIENT=
BACKUP_AGE_IDENTITY=

# === Deploy ===
DB_PASSWORD=                        # senha do PostgreSQL
GHCR_TOKEN=                         # GitHub Container Registry token
PORTAINER_URL=https://portainer.exemplo.com
PORTAINER_TOKEN=                    # Portainer API token
PORTAINER_ENDPOINT_ID=1

# === Prisma — directUrl bypass pgBouncer [Fase 5 Custom Attributes] ===
# Usado por migrations e CREATE/DROP INDEX CONCURRENTLY quando DATABASE_URL
# passa por pgBouncer (conexão via pool não suporta CONCURRENTLY).
# Pode ficar vazio em dev local (fallback para DATABASE_URL).
DIRECT_URL=

# === Data Transfer [Fase 10] ===
# Driver de storage para arquivos de import/export (quarentena, exports, error reports).
# Aceita: local | s3. Default: local (dev).
STORAGE_DRIVER=local
# Raiz local quando STORAGE_DRIVER=local. Necessário em dev.
STORAGE_FS_ROOT=/var/lib/nexus-crm/data-transfer
# Segredo HMAC para assinar URLs do route handler /api/storage/signed (apenas FS).
# Gerar: openssl rand -base64 48
STORAGE_SIGN_SECRET=
# Configuração S3 (obrigatória quando STORAGE_DRIVER=s3).
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Endpoint S3 customizado (opcional — usar para MinIO ou compatíveis).
S3_ENDPOINT=
# Intervalo de polling (ms) que a UI consulta status do job em background.
# Default: 2000.
DATA_TRANSFER_POLL_INTERVAL_MS=2000
